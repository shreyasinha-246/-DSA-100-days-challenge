#include <stdio.h>

int main() {
    int n, pos, x;
    
    scanf("%d", &n);
    
    int arr[100];   // assuming max size 100
    
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    
    scanf("%d", &pos);
    scanf("%d", &x);
    
    int index = pos - 1;  // convert to 0-based
    
    // Shift elements to right
    for(int i = n; i > index; i--) {
        arr[i] = arr[i - 1];
    }
    
    // Insert element
    arr[index] = x;
    
    n++;  // increase size
    
    // Print updated array
    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    
    return 0;
}