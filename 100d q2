#include <stdio.h>

int main() {
    int n, pos;
    
    scanf("%d", &n);
    
    int arr[100];   // assuming max size 100
    
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    
    scanf("%d", &pos);
    
    int index = pos - 1;   // convert 1-based to 0-based
    
    // Shift elements to left
    for(int i = index; i < n - 1; i++) {
        arr[i] = arr[i + 1];
    }
    
    n--;   // reduce size
    
    // Print updated array
    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    
    return 0;
}